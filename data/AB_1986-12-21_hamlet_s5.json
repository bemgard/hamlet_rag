{
  "dokument_id": "AB_1986-12-21_hamlet_s5",
  "chunks": [
    {
      "chunk_id": "AB_1986-12-21_hamlet_s5_chunk-01",
      "text": "Efter nära fyra timmars ös med danaprinsen finns bara en sak att säga. Vilken grupp i världen packar en estrad som Hamlet Rockers?",
      "kontext": {
        "publikation": "Aftonbladet",
        "datum": "1986-12-21",
        "pjäs": "Hamlet",
        "regissör": "Ingmar Bergman",
        "recensent": "Mario Grut",
        "dokumenttyp": "tidningsrecension",
        "rubrik": "Poff! Wham!"
      }
    },
    {
      "chunk_id": "AB_1986-12-21_hamlet_s5_chunk-02",
      "text": "Rena symfonisoundet. Trettisju akustlådor och nio elsträngar. Hennes solotripp \"Jag hoppas att allt ska bli bra\" är rena ljuvliga skizzon.",
      "kontext": {
        "publikation": "Aftonbladet",
        "datum": "1986-12-21",
        "pjäs": "Hamlet",
        "regissör": "Ingmar Bergman",
        "recensent": "Mario Grut",
        "dokumenttyp": "tidningsrecension",
        "rubrik": "Poff! Wham!"
      }
    },
    {
      "chunk_id": "AB_1986-12-21_hamlet_s5_chunk-03",
      "text": "Standarden \"Att vara eller inte vara\" görs om till metalhumor och alternativsketch. Det skulle Derrida diggat.",
      "kontext": {
        "publikation": "Aftonbladet",
        "datum": "1986-12-21",
        "pjäs": "Hamlet",
        "regissör": "Ingmar Bergman",
        "recensent": "Mario Grut",
        "dokumenttyp": "tidningsrecension",
        "rubrik": "Poff! Wham!"
      }
    },
    {
      "chunk_id": "AB_1986-12-21_hamlet_s5_chunk-04",
      "text": "Man skippar tragedin och gör om Hamlet till spektakel. Showen domineras av en känsla som är outsäglig eftersom den övergår de fakta som ges.",
      "kontext": {
        "publikation": "Aftonbladet",
        "datum": "1986-12-21",
        "pjäs": "Hamlet",
        "regissör": "Ingmar Bergman",
        "recensent": "Mario Grut",
        "dokumenttyp": "tidningsrecension",
        "rubrik": "Poff! Wham!"
      }
    },
    {
      "chunk_id": "AB_1986-12-21_hamlet_s5_chunk-05",
      "text": "Här svidar sig Hamlet i läderjacka och solbrillor och rör sig mellan Chicago 1920 och Maciavellis Florens.",
      "kontext": {
        "publikation": "Aftonbladet",
        "datum": "1986-12-21",
        "pjäs": "Hamlet",
        "regissör": "Ingmar Bergman",
        "recensent": "Mario Grut",
        "dokumenttyp": "tidningsrecension",
        "rubrik": "Poff! Wham!"
      }
    },
    {
      "chunk_id": "AB_1986-12-21_hamlet_s5_chunk-06",
      "text": "FASCISTER! Poff! Wham! Bang! En ny ploj i showen för modemedvetna Hamlet Rockers.",
      "kontext": {
        "publikation": "Aftonbladet",
        "datum": "1986-12-21",
        "pjäs": "Hamlet",
        "regissör": "Ingmar Bergman",
        "recensent": "Mario Grut",
        "dokumenttyp": "tidningsrecension",
        "rubrik": "Poff! Wham!"
      }
    },
    {
      "chunk_id": "AB_1986-12-21_hamlet_s5_chunk-07",
      "text": "Projicera in vad du vill i dem. Det är det häftiga bland dessa tablåer. Vad ljuder de av? Maktkamper? Personkonflikter?",
      "kontext": {
        "publikation": "Aftonbladet",
        "datum": "1986-12-21",
        "pjäs": "Hamlet",
        "regissör": "Ingmar Bergman",
        "recensent": "Mario Grut",
        "dokumenttyp": "tidningsrecension",
        "rubrik": "Poff! Wham!"
      }
    },
    {
      "chunk_id": "AB_1986-12-21_hamlet_s5_chunk-08",
      "text": "Det är bara prål och tomhet. Du flyter i det utan att bli ett dugg klokare. Störtskönt!",
      "kontext": {
        "publikation": "Aftonbladet",
        "datum": "1986-12-21",
        "pjäs": "Hamlet",
        "regissör": "Ingmar Bergman",
        "recensent": "Mario Grut",
        "dokumenttyp": "tidningsrecension",
        "rubrik": "Poff! Wham!"
      }
    }
  ]
}